<!DOCTYPE html>
<html lang='en'>
<head>
  <meta charset='UTF-8'>
  <meta name='viewport' content='width=device-width, initial-scale=1.0'>
  <title>{{ report_title }}</title>
  <script src='https://cdn.plot.ly/plotly-2.32.0.min.js'></script>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: Arial, sans-serif; background: #f8f9fa; color: #1a1a1a; }
    .container { max-width: 960px; margin: 0 auto; padding: 2rem; }
    .cover { background: #1F4E79; color: white; padding: 3rem 2rem; border-radius: 8px; margin-bottom: 2rem; }
    .cover h1 { font-size: 2.2rem; margin-bottom: 1rem; }
    .cover p { font-size: 1rem; opacity: 0.85; line-height: 1.6; }
    .section { background: white; border-radius: 8px; padding: 2rem; margin-bottom: 1.5rem; box-shadow: 0 1px 4px rgba(0,0,0,0.08); }
    .section h2 { color: #1F4E79; border-bottom: 3px solid #2E75B6; padding-bottom: 0.5rem; margin-bottom: 1rem; }
    .narrative { line-height: 1.7; color: #333; margin-bottom: 1.5rem; }
    .chart-container { margin: 1.5rem 0; }
    .chart-caption { text-align: center; font-size: 0.85rem; color: #666; font-style: italic; margin-top: 0.5rem; }
    .callout { background: #D6E4F0; border-left: 4px solid #2E75B6; padding: 1rem 1.2rem; border-radius: 0 6px 6px 0; margin: 1rem 0; }
    .callout .label { font-size: 0.75rem; font-weight: bold; color: #1F4E79; text-transform: uppercase; letter-spacing: 0.05em; }
    .callout .text { margin-top: 0.3rem; font-size: 0.95rem; }
    .conclusion { background: #1F4E79; color: white; padding: 2rem; border-radius: 8px; margin-top: 2rem; }
    .conclusion h2 { color: white; border-bottom: 2px solid rgba(255,255,255,0.3); padding-bottom: 0.5rem; margin-bottom: 1rem; }
    .footer { text-align: center; padding: 2rem; color: #999; font-size: 0.8rem; }
  </style>
</head>
<body>
  <div class='container'>
    <div class='cover'>
      <h1>{{ report_title }}</h1>
      <p>{{ executive_summary }}</p>
    </div>
 
    {% for section in sections %}
    <div class='section'>
      <h2>{{ section.title }}</h2>
      <p class='narrative'>{{ section.narrative }}</p>
 
      {% if section.plotly_json %}
      <div class='chart-container'>
        <div id='chart-{{ loop.index }}'></div>
        <p class='chart-caption'>{{ section.caption }}</p>
      </div>
      <script>
        (function() {
          var spec = {{ section.plotly_json | safe }};
          Plotly.newPlot('chart-{{ loop.index }}', spec.data, spec.layout, {responsive: true});
        })();
      </script>
      {% endif %}
 
      {% if section.callout_text %}
      <div class='callout'>
        <div class='label'>{{ section.callout_label }}</div>
        <div class='text'>{{ section.callout_text }}</div>
      </div>
      {% endif %}
    </div>
    {% endfor %}
 
    <div class='conclusion'>
      <h2>Conclusion</h2>
      <p>{{ conclusion }}</p>
    </div>
    <div class='footer'>Generated by CaseStudy Forge</div>
  </div>
</body>
</html>
